# Server Config
PORT=3000
NODE_ENV=development

# Session Security
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# DB Encryption Key (Must be 32 bytes / 64 hex characters)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Automatic Database Backup Interval (in minutes)
BACKUP_INTERVAL_MINUTES=60

# SMTP Configuration (For real emails in production; falls back to logs if undefined)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="ForgeUp <no-reply@forgeup.com>"

